# Database - SQLite (default)
DATABASE_URL="file:./data/travelexpense.db"
# For PostgreSQL use:
# DATABASE_URL="postgresql://user:password@localhost:5432/travelexpense"

# Deployment subpath (e.g. /travel-expense)
# If set, the app will be served at NEXTAUTH_URL + BASE_PATH
# Leave empty for root deployment
BASE_PATH=""

# NextAuth
# IMPORTANT: If BASE_PATH is set, NEXTAUTH_URL must include it:
#   NEXTAUTH_URL="https://example.com/travel-expense"
# The Google redirect URI must also include the basePath:
#   https://example.com/travel-expense/api/auth/callback/google
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-string"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-In (https://developer.apple.com/account/resources/)
APPLE_CLIENT_ID="com.your.service.id"
APPLE_TEAM_ID="your-team-id"
APPLE_KEY_ID="your-key-id"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourKeyDataHere\n-----END PRIVATE KEY-----"

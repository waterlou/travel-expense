generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  members       TravelMember[]
  invitationsUsed Invitation[] @relation("UsedInvitations")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Travel {
  id                String   @id @default(cuid())
  name              String
  prefix            String   @unique
  startDate         String?
  endDate           String?
  mainCurrency      String   @default("USD")
  currencies        String   @default("[]")
  expensePermission Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  members       TravelMember[]
  expenses      Expense[]
  invitations   Invitation[]
  exchangeRates ExchangeRate[]
  memberGroups  MemberGroup[]
}

model TravelMember {
  id       String  @id @default(cuid())
  travelId String
  userId   String?
  name     String
  isAdmin  Boolean @default(false)
  groupId  String?

  travel Travel     @relation(fields: [travelId], references: [id], onDelete: Cascade)
  user   User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  group  MemberGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  paidExpenses Expense[]      @relation("Payer")
  splits       ExpenseSplit[]

  @@unique([travelId, userId])
}

model MemberGroup {
  id        String   @id @default(cuid())
  travelId  String
  name      String
  createdAt DateTime @default(now())

  travel  Travel        @relation(fields: [travelId], references: [id], onDelete: Cascade)
  members TravelMember[]
}

model Expense {
  id          String   @id @default(cuid())
  travelId    String
  date        String
  description String?
  amount      Float
  currency    String
  paidById    String
  extraPayers String?  @default("[]")
  splitType   String   @default("equal")
  confirmed   Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  travel Travel       @relation(fields: [travelId], references: [id], onDelete: Cascade)
  paidBy TravelMember @relation("Payer", fields: [paidById], references: [id])
  splits  ExpenseSplit[]
}

model ExpenseSplit {
  id        String @id @default(cuid())
  expenseId String
  memberId  String
  amount    Float?

  expense Expense      @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member  TravelMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([expenseId, memberId])
}

model Invitation {
  id        String   @id @default(cuid())
  travelId  String
  code      String   @unique
  email     String?
  usedById  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  travel Travel @relation(fields: [travelId], references: [id], onDelete: Cascade)
  usedBy User?  @relation("UsedInvitations", fields: [usedById], references: [id])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  travelId     String
  fromCurrency String
  toCurrency   String
  rate         Float
  updatedAt    DateTime @updatedAt

  travel Travel @relation(fields: [travelId], references: [id], onDelete: Cascade)

  @@unique([travelId, fromCurrency, toCurrency])
}
